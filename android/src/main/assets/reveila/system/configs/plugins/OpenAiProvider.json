{
  "plugin" : {
    "name" : "OpenAiProvider",
    "displayName" : "OpenAI LLM Provider",
    "version" : "1.0.0",
    "description" : "LLM Provider for OpenAI models.",
    "author" : "Reveila-Suite",
    "class" : "com.reveila.ai.OpenAiProvider",
    "thread-safe" : true,
    "arguments" : [ {
      "name" : "apiKey",
      "type" : "java.lang.String",
      "value" : "REF:OPENAI_PROD_KEY"
    }, {
      "name" : "model",
      "type" : "java.lang.String",
      "value" : "gpt-4o"
    }, {
      "name" : "temperature",
      "type" : "double",
      "value" : 0.7
    } ],
    "dependencies" : [ "HttpClientService" ],
    "methods" : [ ],
    "required-roles" : [ "*" ],
    "agency_perimeter" : {
      "tier" : "Tier 2 (Sensitive)",
      "access_scopes" : [ "db.read", "fs.read:/reports/tmp" ],
      "network_egress" : {
        "allowed_domains" : [ "api.internal-analytics.com" ],
        "protocols" : [ "https" ]
      },
      "human_in_the_loop" : {
        "trigger_on" : [ "db.delete", "db.drop" ],
        "escalation_policy" : "admin_approval_required"
      },
      "resource_limits" : {
        "max_memory_mb" : 512,
        "max_execution_sec" : 30
      }
    }
  }
}